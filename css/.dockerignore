**/node_modules/
**/*.log
extensions/*/package-lock.json
# ESM build output is regenerated by `npm run build:esm` inside the container
extensions/markdown-rdfa/dist/
# dist-cjs/ is NOT excluded: it holds hand-written Components.js metadata
# (converter.jsonld, components/*.jsonld, package.json) that the container
# build doesn't regenerate. The compiled .js/.d.ts files under dist-cjs/ are
# host artifacts, but they're overwritten by `npm run build:cjs` in the
# container, so they're harmless.
