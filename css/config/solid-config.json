{
  "@context": [
    "https://linkedsoftwaredependencies.org/bundles/npm/@solid/community-server/^8.0.0/components/context.jsonld",
    "https://linkedsoftwaredependencies.org/bundles/npm/shape-validation-component/^2.0.0/components/context.jsonld"
  ],
  "import": [
    "css:config/file.json"
  ],
  "@graph": [
    {
      "comment": "cogitarelink-solid: CSS v8 alpha + SHACL shape validation via ldp:constrainedBy"
    },
    {
      "comment": "Add ldp:constrainedBy to the existing LinkRel metadata writer so it appears as a Link header.",
      "@type": "Override",
      "overrideInstance": { "@id": "urn:solid-server:default:MetadataWriter_LinkRel" },
      "overrideParameters": {
        "@type": "LinkRelMetadataWriter",
        "linkRelMap": [
          {
            "LinkRelMetadataWriter:_linkRelMap_key": "http://www.w3.org/1999/02/22-rdf-syntax-ns#type",
            "LinkRelMetadataWriter:_linkRelMap_value": "type"
          },
          {
            "LinkRelMetadataWriter:_linkRelMap_key": "http://www.w3.org/ns/ldp#inbox",
            "LinkRelMetadataWriter:_linkRelMap_value": "http://www.w3.org/ns/ldp#inbox"
          },
          {
            "LinkRelMetadataWriter:_linkRelMap_key": "http://www.w3.org/ns/ldp#constrainedBy",
            "LinkRelMetadataWriter:_linkRelMap_value": "http://www.w3.org/ns/ldp#constrainedBy"
          }
        ]
      }
    },
    {
      "@type": "Override",
      "overrideInstance": { "@id": "urn:solid-server:default:ResourceStore_Patching" },
      "overrideParameters": {
        "@type": "PatchingStore",
        "source": { "@id": "urn:shape-validation:default:ResourceStore_Shape" },
        "patchHandler": { "@id": "urn:solid-server:default:PatchHandler" }
      }
    },
    {
      "comment": "Validates resources when parent container has ldp:constrainedBy in its metadata.",
      "@id": "urn:shape-validation:default:ResourceStore_Shape",
      "@type": "ShapeValidationStore",
      "identifierStrategy": { "@id": "urn:solid-server:default:IdentifierStrategy" },
      "metadataStrategy": { "@id": "urn:solid-server:default:MetadataStrategy" },
      "converter": { "@id": "urn:solid-server:default:RepresentationConverter" },
      "source": { "@id": "urn:solid-server:default:ResourceStore_Converting" },
      "validator": {
        "@id": "urn:shape-validation:default:ShaclValidator",
        "@type": "ShaclValidator",
        "converter": { "@id": "urn:solid-server:default:RepresentationConverter" },
        "auxiliaryStrategy": { "@id": "urn:solid-server:default:AuxiliaryStrategy" }
      }
    }
  ]
}
