@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#>.
@prefix dct:   <http://purl.org/dc/terms/>.
@prefix void:  <http://rdfs.org/ns/void#>.
@prefix vault: <https://pod.vardeman.me/vault/ontology#>.

<> a vault:ProjectContainer ;
    rdfs:label "Projects" ;
    dct:description "Time-bound efforts serving Areas. Each project has tasks, a timeline, and connects to an Area via vault:area." ;
    vault:paraCategory vault:Projects ;
    vault:memoryPartition vault:TaskState ;
    void:class vault:Project ;
    vault:agentGuidance "Projects are active work. Check vault:area to understand which Area a project serves." .
