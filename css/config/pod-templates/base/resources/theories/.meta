@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#>.
@prefix dct:   <http://purl.org/dc/terms/>.
@prefix skos:  <http://www.w3.org/2004/02/skos/core#>.
@prefix sh:    <http://www.w3.org/ns/shacl#>.
@prefix vault: <https://pod.vardeman.me/vault/ontology#>.

<> a skos:Collection ;
    rdfs:label "Theories" ;
    dct:description "Synthesized arguments combining multiple concepts and sources into structured claims." ;
    dct:type vault:Resources, vault:Symbolic ;
    sh:agentInstruction "Theory notes synthesize concepts. Follow vault:extends to see what a theory builds on." .
