node_modules/
dist/
# dist-cjs/ is partially tracked: the hand-written Components.js metadata
# (converter.jsonld, components/*.jsonld, package.json) is committed so CSS
# can load the extension, but the tsc-built JavaScript is a build artifact
# regenerated by `npm run build:cjs` or the Dockerfile step.
dist-cjs/*.js
package-lock.json
*.log
