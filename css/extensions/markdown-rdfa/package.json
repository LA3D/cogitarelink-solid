{
  "name": "markdown-rdfa",
  "version": "0.1.0",
  "description": "Render Solid Pod markdown notes to semantically-annotated HTML with resolved wikilinks and RDFa attributes. CSS v8 RepresentationConverter extension.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist-cjs/converter.js"
    },
    "./converter": {
      "require": "./dist-cjs/converter.js"
    }
  },
  "lsd:module": "https://linkedsoftwaredependencies.org/bundles/npm/markdown-rdfa",
  "lsd:components": "dist-cjs/components/components.jsonld",
  "lsd:contexts": {
    "https://linkedsoftwaredependencies.org/bundles/npm/markdown-rdfa/^0.1.0/components/context.jsonld": "dist-cjs/components/context.jsonld"
  },
  "lsd:importPaths": {
    "https://linkedsoftwaredependencies.org/bundles/npm/markdown-rdfa/^0.1.0/components/": "dist-cjs/components/",
    "https://linkedsoftwaredependencies.org/bundles/npm/markdown-rdfa/^0.1.0/dist-cjs/": "dist-cjs/"
  },
  "bin": {
    "md-rdfa": "./dist/cli.js"
  },
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs",
    "build:esm": "tsc",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "render": "tsx src/cli.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "unified": "^11.0.5",
    "remark-parse": "^11.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-rehype": "^11.1.1",
    "rehype-document": "^7.0.3",
    "rehype-format": "^5.0.1",
    "rehype-stringify": "^10.0.1",
    "unist-util-visit": "^5.0.0",
    "hast-util-from-html": "^2.0.3"
  },
  "peerDependencies": {
    "@solid/community-server": "*"
  },
  "devDependencies": {
    "@solid/community-server": "^8.0.0-alpha.3",
    "@types/node": "^22.0.0",
    "@types/mdast": "^4.0.4",
    "@types/hast": "^3.0.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
