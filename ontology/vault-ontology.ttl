# Vault ontology — terms for pod content and classification
#
# Namespace: https://pod.vardeman.me/vault/ontology#
# Design: Maximize reuse of SKOS, Dublin Core, SHACL 1.2, PROV.
# Only define terms here when no standard vocabulary covers the semantics.
#
# Standard vocabularies used (NOT redefined here):
#   skos:    Content organization (Concept, ConceptScheme, prefLabel, related, inScheme)
#   dct:     Metadata (created, subject, source, isPartOf, type, description)
#   sh:      Agent guidance (agentInstruction, intent, description) — SHACL 1.2 §8
#   void:    Dataset descriptions (on void:Dataset instances only)
#   prov:    Provenance (wasDerivedFrom, wasAttributedTo)
#   ldp:     Containment (contains, BasicContainer) — CSS-generated
#   solid:   Discovery (publicTypeIndex, TypeIndex, TypeRegistration)
#
# What IS defined here:
#   - Note types not covered by SKOS (TheoryNote, LiteratureNote, etc.)
#   - Relationship properties from vault Breadcrumbs (extends, supports, criticizes)
#   - SKOS ConceptSchemes for PARA categories and memory partitions (D30, D34)

@prefix vault: <https://pod.vardeman.me/vault/ontology#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:   <http://purl.org/dc/terms/> .

# ============================================================
# Note types (content layer)
# All knowledge-bearing types are subClassOf skos:Concept (D34)
# ============================================================

vault:TheoryNote a rdfs:Class ;
    rdfs:label "Theory Note" ;
    rdfs:comment "Synthesized argument combining multiple concepts and sources." ;
    rdfs:subClassOf skos:Concept .

vault:LiteratureNote a rdfs:Class ;
    rdfs:label "Literature Note" ;
    rdfs:comment "Notes on a paper, book, or external source." ;
    rdfs:subClassOf skos:Concept .

vault:MethodNote a rdfs:Class ;
    rdfs:label "Method Note" ;
    rdfs:comment "Description of a method, technique, or process." ;
    rdfs:subClassOf skos:Concept .

vault:Project a rdfs:Class ;
    rdfs:label "Project" ;
    rdfs:comment "Time-bound effort serving an Area of Focus." .

vault:Area a rdfs:Class ;
    rdfs:label "Area of Focus" ;
    rdfs:comment "Persistent life area (Pullein/GAPRA framework)." .

# ============================================================
# Relationship properties (Breadcrumbs edge fields)
# These map directly to Obsidian vault frontmatter edges.
# TODO: evaluate CiTO alignment (cito:extends, cito:supports,
# cito:critiques) for future interoperability.
# ============================================================

vault:area a owl:ObjectProperty ;
    rdfs:label "area" ;
    rdfs:comment "Links a resource to the Area of Focus it serves." ;
    rdfs:range vault:Area .

vault:extends a owl:ObjectProperty ;
    rdfs:label "extends" ;
    rdfs:comment "This note builds upon or extends another." .

vault:supports a owl:ObjectProperty ;
    rdfs:label "supports" ;
    rdfs:comment "This note provides evidence for a claim." .

vault:criticizes a owl:ObjectProperty ;
    rdfs:label "criticizes" ;
    rdfs:comment "This note challenges or argues against a claim." .

vault:concept a owl:ObjectProperty ;
    rdfs:label "concept" ;
    rdfs:comment "Links a note to a related concept." .

# ============================================================
# PARA classification scheme (D30)
# Modeled as SKOS ConceptScheme per D34. Containers use
# dct:type to link to their PARA category.
# ============================================================

vault:PARAScheme a skos:ConceptScheme ;
    skos:prefLabel "PARA Framework" ;
    rdfs:comment "Projects, Areas, Resources, Archive — organizational framework (Pullein/GAPRA)." .

vault:Projects a skos:Concept ;
    skos:inScheme vault:PARAScheme ;
    skos:prefLabel "Projects" .

vault:Areas a skos:Concept ;
    skos:inScheme vault:PARAScheme ;
    skos:prefLabel "Areas" .

vault:Resources a skos:Concept ;
    skos:inScheme vault:PARAScheme ;
    skos:prefLabel "Resources" .

vault:Archive a skos:Concept ;
    skos:inScheme vault:PARAScheme ;
    skos:prefLabel "Archive" .

# ============================================================
# Memory partition scheme (D30)
# Agentic memory partitions as SKOS concepts. Containers use
# dct:type to link to their partition.
# ============================================================

vault:MemoryPartitionScheme a skos:ConceptScheme ;
    skos:prefLabel "Agentic Memory Partitions" ;
    rdfs:comment "Classification of pod containers by memory function (D30)." .

vault:Symbolic a skos:Concept ;
    skos:inScheme vault:MemoryPartitionScheme ;
    skos:prefLabel "Symbolic Memory" ;
    skos:definition "Declarative knowledge — concepts, theories, facts." .

vault:Procedural a skos:Concept ;
    skos:inScheme vault:MemoryPartitionScheme ;
    skos:prefLabel "Procedural Memory" ;
    skos:definition "Behavioral knowledge — shapes, queries, validation rules." .

vault:TaskState a skos:Concept ;
    skos:inScheme vault:MemoryPartitionScheme ;
    skos:prefLabel "Task State Memory" ;
    skos:definition "Active work state — projects, tasks, progress." .
